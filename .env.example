# ─── JSONBin.io — Consecutivo en la nube ───────────────────────────────────
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el archivo ".env" a Git (ya está en .gitignore).

# El ID del Bin (lo ves en la URL del Bin: .../b/AQUI_VA_EL_ID)
VITE_JSONBIN_BIN_ID=PEGA_TU_BIN_ID_AQUI

# La API Key en base64 — evita problemas con el caracter $ en .env
# Para obtener el base64 de tu clave, crea un archivo enc.py con:
#   import base64; k='TU_API_KEY'; print(base64.b64encode(k.encode()).decode())
# y ejecuta: python enc.py
VITE_JSONBIN_API_KEY_B64=PEGA_AQUI_EL_BASE64_DE_TU_API_KEY
